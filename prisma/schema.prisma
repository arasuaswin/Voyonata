generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  full_name      String
  email          String   @unique
  password_hash  String
  email_verified Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  refreshTokens  RefreshToken[]
  passkeys       Passkey[]
  trips          Trip[]

  @@index([email])
}

model Trip {
  id           String   @id @default(uuid())
  destination  String
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  travelers    Int      @default(1)
  budget       String   @default("moderate") // budget | moderate | luxury
  interests    String[] // e.g. ["culture", "food", "adventure"]
  notes        String?
  itinerary    Json     // The generated day-by-day plan
  status       String   @default("draft") // draft | planned | completed
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([userId])
}

model Passkey {
  id               String   @id @default(uuid())
  credentialID     Bytes    @unique
  credentialPublicKey Bytes
  counter          Int      @default(0)
  credentialDeviceType String
  credentialBackedUp   Boolean @default(false)
  transports       String?  // Stored as comma separated string or JSON
  
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
  @@index([token])
}
